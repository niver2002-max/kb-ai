	<section id="content"><script type="text/javascript">
	$(document).ready(function() {
		var form1 = 'form[name="register-form"]';
		$(form1).validate({
			onSubmitOnly: false,
			autoScroll: false,
			message: 'Please complete all compulsory fields',
			messageElement: $('.error-message', form1),
			setting: [
				[ 'email', {
					method: [
						[ 'req' ],
						[ 'email' ]
					],
					errorElement: $('[name="email"]', form1).parents('.input-container')
				} ],
				[ 'password1', {
					method: [
						[ 'req' ]					
					],
					errorElement: $('[name="password1"]', form1).parents('.input-container')
				} ],
				[ 'password2', {
					method: [
						[ 'req' ]
					],
					errorElement: $('[name="password2"]', form1).parents('.input-container'),
					onSuccess: function(form, element, validator) {
						return validator.val($(element).val(), 'equal=' + $('input[name="password1"]', form1).val());
					}
				} ],
				[ 'tel', {
					method: [
						[ 'req' ]					
					],
					errorElement: $('[name="tel"]', form1).parents('.input-container')
				} ],
				[ 'captcha1', {
					method: [
						[ 'req' ],			
						[ 'minlen', 4 ],			
						[ 'maxlen', 4 ],			
						[ 'remote', genurl('form', 'verify', 1), lang.invalid_captcha ]				
					]
				} ]
			],
			onError: function(form) {
				$('.error-message2', form1).html('');
			}
		});
		
		var form2 = 'form[name="login-form"]';
		$(form2).validate({
			onSubmitOnly: false,
			autoScroll: false,
			message: 'Please complete all compulsory fields',
			messageElement: $('.error-message', form2),
			setting: [
				[ 'email', {
					method: [
						[ 'req' ],
						[ 'email' ]
					],
					errorElement: $('[name="email"]', form2).parents('.input-container')
				} ],
				[ 'password', {
					method: [
						[ 'req' ]					
					],
					errorElement: $('[name="password"]', form2).parents('.input-container')
				} ],
				[ 'captcha2', {
					method: [
						[ 'req' ],			
						[ 'minlen', 4 ],			
						[ 'maxlen', 4 ],			
						[ 'remote', genurl('form', 'verify', 2), lang.invalid_captcha ]				
					]
				} ]
			],
			onError: function(form) {
				$('.error-message2', form2).html('');
			}
		});
		
		$('#refresh1').click(function(e) {
			$('#captcha1').attr('src', genurl('form', 'captcha', '1/' + new Date().getTime()));
			e.preventDefault();
		});
		
		$('#refresh2').click(function(e) {
			$('#captcha2').attr('src', genurl('form', 'captcha', '2/' + new Date().getTime()));
			e.preventDefault();
		});
		
		$('.link').colorbox({
			iframe: true,
			innerWidth: '100%',
			innerHeight: '100%',
			maxWidth: 600,
			maxHeight: 411,
			scrolling: false
		});
	});
</script>
